# 4. كاشف القطيعة الاستباقي (Proactive Rupture Detector)
# ============================================================

class ProactiveRuptureDetector:
    """
    يكتشف القطائع الإبستمولوجية بشكل استباقي (توقعها قبل حدوثها).
    يستخدم تحليل الاتجاهات والنماذج التنبؤية البسيطة.
    """

    def __init__(self):
        self.history: Dict[str, List[Dict]] = defaultdict(list)
        self.rupture_threshold = 0.35
        self.prediction_window = 3  # عدد النقاط الزمنية للنظر إلى الأمام

    def record_state(self, entity_id: str, ont_profile: OntologicalProfile, epi_profile: EpistemologicalProfile):
        """تسجيل حالة معرفية للكيان."""
        self.history[entity_id].append({
            "timestamp": datetime.utcnow().isoformat(),
            "ontology": ont_profile.dominant_category,
            "epistemology": epi_profile.dominant_category,
            "ont_scores": ont_profile.scores.copy(),
            "epi_scores": epi_profile.scores.copy(),
            "depth": ont_profile.root_depth
        })

    def detect_rupture(self, entity_id: str, new_ont: OntologicalProfile, new_epi: EpistemologicalProfile) -> Optional[EpistemologicalRupture]:
        """اكتشاف القطيعة الحالية (مباشر)."""
        if entity_id not in self.history or len(self.history[entity_id]) < 2:
            return None

        # استرجاع آخر حالة
        last_state = self.history[entity_id][-1]
        old_ont_dom = last_state["ontology"]
        old_epi_dom = last_state["epistemology"]

        # حساب التغير
        ont_change = self._calculate_change(last_state["ont_scores"], new_ont.scores)
        epi_change = self._calculate_change(last_state["epi_scores"], new_epi.scores)

        if ont_change > self.rupture_threshold or epi_change > self.rupture_threshold:
            return EpistemologicalRupture(
                id=hashlib.md5(f"{entity_id}_{datetime.utcnow().isoformat()}".encode()).hexdigest()[:16],
                entity_id=entity_id,
                from_ontology=old_ont_dom,
                to_ontology=new_ont.dominant_category,
                from_epistemology=old_epi_dom,
                to_epistemology=new_epi.dominant_category,
                rupture_point=datetime.utcnow().isoformat(),
                description=f"تحول أنطولوجي: {old_ont_dom} → {new_ont.dominant_category}، إبستمولوجي: {old_epi_dom} → {new_epi.dominant_category}",
                severity=max(ont_change, epi_change),
                timestamp=datetime.utcnow().isoformat(),
                predicted=False,
                prediction_confidence=0.0
            )
        return None

    def predict_rupture(self, entity_id: str) -> List[Dict]:
        """
        توقع القطائع المستقبلية بناءً على الاتجاهات التاريخية.
        """
        if entity_id not in self.history or len(self.history[entity_id]) < 4:
            return []

        states = self.history[entity_id]
        if len(states) < self.prediction_window:
            return []

        # تحليل الاتجاهات الحديثة
        recent = states[-self.prediction_window:]
        ont_trends = self._calculate_trends(recent, "ont_scores")
        epi_trends = self._calculate_trends(recent, "epi_scores")

        predictions = []

        # التنبؤ بالتغير في الأنطولوجيا
        for cat, trend in ont_trends.items():
            if trend > 0.02:  # زيادة مستمرة
                predictions.append({
                    "type": "ontology",
                    "category": cat,
                    "trend": round(trend, 3),
                    "confidence": min(1.0, trend * 10),
                    "direction": "تصاعدي",
                    "estimated_time": "قريب"
                })
            elif trend < -0.02:
                predictions.append({
                    "type": "ontology",
                    "category": cat,
                    "trend": round(trend, 3),
                    "confidence": min(1.0, abs(trend) * 10),
                    "direction": "تنازلي",
                    "estimated_time": "قريب"
                })

        # التنبؤ بالتغير في الإبستمولوجيا
        for cat, trend in epi_trends.items():
            if trend > 0.02:
                predictions.append({
                    "type": "epistemology",
                    "category": cat,
                    "trend": round(trend, 3),
                    "confidence": min(1.0, trend * 10),
                    "direction": "تصاعدي",
                    "estimated_time": "قريب"
                })
            elif trend < -0.02:
                predictions.append({
                    "type": "epistemology",
                    "category": cat,
                    "trend": round(trend, 3),
                    "confidence": min(1.0, abs(trend) * 10),
                    "direction": "تنازلي",
                    "estimated_time": "قريب"
                })

        return predictions

    def _calculate_change(self, old_scores: Dict, new_scores: Dict) -> float:
        total = 0.0
        for cat in old_scores:
            total += abs(old_scores.get(cat, 0) - new_scores.get(cat, 0))
        return round(total / 2, 3)

    def _calculate_trends(self, states: List[Dict], score_key: str) -> Dict[str, float]:
        """
        حساب اتجاهات التغير في الفئات خلال النقاط الزمنية الأخيرة.
        يستخدم الانحدار الخطي البسيط.
        """
        if len(states) < 2:
            return {}
        trends = {}
        # استخراج جميع الفئات
        categories = set()
        for s in states:
            categories.update(s[score_key].keys())

        for cat in categories:
            values = []
            for s in states:
                values.append(s[score_key].get(cat, 0))
            if len(values) > 1:
                x = np.arange(len(values))
                slope = np.polyfit(x, values, 1)[0]
                trends[cat] = float(slope)
        return trends

