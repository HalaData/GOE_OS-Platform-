# 6. المحرك الرئيسي (v2.0 - النهائي المتكامل)
# ============================================================

class EpistemicOntologicalEngineV2:
    """
    المحرك الرئيسي للحوكمة الإبستمولوجية والأنطولوجية - النسخة النهائية.
    يطبق الموجهات الخمسة، الاستباقية، التعمق في الجذور.
    """

    def __init__(self):
        self.depth_analyzer = MultiDepthAnalyzer()
        self.rupture_detector = ProactiveRuptureDetector()
        self.lineage_tracker = KnowledgeLineageTracker()
        self.identity_cache: Dict[str, PhilosophicalIdentity] = {}
        logger.info("🧠 Epistemic-Ontological Engine v2.0 initialized.")

    def analyze_text(self, text: str, entity_id: str = None) -> Dict:
        """
        تحليل شامل للنص: أنطولوجيا، إبستمولوجيا، قطعية، سلالة، استباق.
        """
        # 1. التحليل متعدد المستويات
        depth_results = self.depth_analyzer.analyze_full_depth(text)

        # 2. استخلاص الملفات على المستوى المتوسط (كمرجع)
        ont_profile = depth_results["متوسط"]["ontology"]
        epi_profile = depth_results["متوسط"]["epistemology"]

        # 3. تسجيل الحالة للكشف عن القطيعة
        if entity_id:
            self.rupture_detector.record_state(entity_id, ont_profile, epi_profile)

        # 4. كشف القطيعة الحالية
        rupture = None
        if entity_id:
            rupture = self.rupture_detector.detect_rupture(entity_id, ont_profile, epi_profile)

        # 5. التنبؤ بالقطيعة المستقبلية
        predictions = []
        if entity_id:
            predictions = self.rupture_detector.predict_rupture(entity_id)

        # 6. تتبع السلالة المعرفية
        lineage = []
        if entity_id:
            lineage = self.lineage_tracker.find_lineage(text, entity_id)
            self.lineage_tracker.register_idea(text, entity_id)

        # 7. توليد الهوية الفلسفية
        identity = self._generate_identity(entity_id, ont_profile, epi_profile, rupture, predictions)

        # 8. التقرير النهائي (شفاف)
        report = {
            "entity_id": entity_id,
            "depth_analysis": {
                depth: {
                    "ontology": {
                        "dominant": r["ontology"].dominant_category,
                        "scores": r["ontology"].scores,
                        "confidence": r["ontology"].confidence,
                        "evidence": r["ontology"].evidence
                    },
                    "epistemology": {
                        "dominant": r["epistemology"].dominant_category,
                        "scores": r["epistemology"].scores,
                        "confidence": r["epistemology"].confidence,
                        "evidence": r["epistemology"].evidence
                    }
                } for depth, r in depth_results.items()
            },
            "rupture": {
                "detected": rupture is not None,
                "details": rupture.__dict__ if rupture else None
            },
            "predictions": predictions,
            "lineage": lineage,
            "philosophical_identity": identity.__dict__ if identity else None,
            "timestamp": datetime.utcnow().isoformat()
        }

        return report

    def _generate_identity(self, entity_id: str, ont: OntologicalProfile, epi: EpistemologicalProfile,
                           rupture: Optional[EpistemologicalRupture], predictions: List[Dict]) -> Optional[PhilosophicalIdentity]:
        """توليد الهوية الفلسفية للكيان."""
        if not entity_id:
            return None

        # تحديد مرحلة التحول (دورة حياة الفراشة)
        stages = self._get_transformation_stage(entity_id, rupture)

        # حساب درجة الاستقرار
        stability = self._calculate_stability(entity_id)

        identity = PhilosophicalIdentity(
            entity_id=entity_id,
            ontological_dominant=ont.dominant_category,
            epistemological_dominant=epi.dominant_category,
            root_depth=ont.root_depth,
            lineage=[],
            transformation_stage=stages[-1] if stages else "egg",
            stability_score=stability
        )

        self.identity_cache[entity_id] = identity
        return identity

    def _get_transformation_stage(self, entity_id: str, rupture: Optional[EpistemologicalRupture]) -> List[str]:
        """تحديد مرحلة التحول المعرفي (دورة حياة الفراشة)."""
        if entity_id not in self.rupture_detector.history:
            return ["egg"]

        history = self.rupture_detector.history[entity_id]
        if len(history) < 2:
            return ["egg"]

        stages = []
        if rupture:
            stages.append("pupa")  # تحول جاري
        elif len(history) > 5:
            stages.append("butterfly")  # نضج
        elif len(history) > 3:
            stages.append("larva")  # نمو
        else:
            stages.append("egg")

        return stages

    def _calculate_stability(self, entity_id: str) -> float:
        """حساب درجة الاستقرار المعرفي للكيان."""
        if entity_id not in self.rupture_detector.history:
            return 1.0

        history = self.rupture_detector.history[entity_id]
        if len(history) < 2:
            return 1.0

        # حساب متوسط التغير بين الحالات المتتالية
        changes = []
        for i in range(1, len(history)):
            ont_change = self.rupture_detector._calculate_change(
                history[i-1]["ont_scores"],
                history[i]["ont_scores"]
            )
            epi_change = self.rupture_detector._calculate_change(
                history[i-1]["epi_scores"],
                history[i]["epi_scores"]
            )
            changes.append((ont_change + epi_change) / 2)

        avg_change = sum(changes) / len(changes) if changes else 0
        stability = max(0.0, 1.0 - avg_change * 3)
        return round(stability, 2)

    def get_philosophical_identity(self, entity_id: str) -> Optional[Dict]:
        """استرجاع الهوية الفلسفية المخزنة لكيان."""
        if entity_id in self.identity_cache:
            return self.identity_cache[entity_id].__dict__
        return None

    def get_history(self, entity_id: str, limit: int = 20) -> List[Dict]:
        """استرجاع التاريخ المعرفي للكيان."""
        if entity_id not in self.rupture_detector.history:
            return []
        return self.rupture_detector.history[entity_id][-limit:]

