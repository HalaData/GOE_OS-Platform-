# 3. المحلل متعدد المستويات (للتعمق في الجذور)
# ============================================================

class MultiDepthAnalyzer:
    """
    يحلل النصوص على ثلاثة مستويات: سطحي، متوسط، عميق.
    يستخدم مجموعات كلمات مفتاحية مختلفة لكل مستوى.
    """

    def __init__(self):
        self.depth_levels = ["سطحي", "متوسط", "عميق"]
        self.ontology_keywords = {
            "سطحي": KeywordSets.SURFACE_ONTOLOGY,
            "متوسط": KeywordSets.MID_ONTOLOGY,
            "عميق": KeywordSets.DEEP_ONTOLOGY
        }
        self.epistemology_keywords = {
            "سطحي": KeywordSets.SURFACE_EPISTEMOLOGY,
            "متوسط": KeywordSets.MID_EPISTEMOLOGY,
            "عميق": KeywordSets.DEEP_EPISTEMOLOGY
        }

    def analyze_ontology(self, text: str, depth: str = "متوسط") -> OntologicalProfile:
        """تحليل أنطولوجي بمستوى عمق محدد."""
        if depth not in self.ontology_keywords:
            depth = "متوسط"
        keywords = self.ontology_keywords[depth]

        scores = {cat: 0 for cat in keywords.keys()}
        evidence = []

        for category, words in keywords.items():
            count = 0
            for word in words:
                count += len(re.findall(rf'\b{word}\b', text, re.I))
            scores[category] = count
            if count > 0:
                evidence.append(f"{depth}: كلمات من فئة '{category}' ({count})")

        total = sum(scores.values())
        if total > 0:
            for cat in scores:
                scores[cat] = round(scores[cat] / total, 3)

        dominant = max(scores, key=scores.get) if scores else OntologicalCategory.MATERIALIST
        confidence = min(1.0, len(evidence) / 10)

        return OntologicalProfile(
            dominant_category=dominant,
            scores=scores,
            evidence=evidence[:5],
            confidence=confidence,
            root_depth=depth
        )

    def analyze_epistemology(self, text: str, depth: str = "متوسط") -> EpistemologicalProfile:
        """تحليل إبستمولوجي بمستوى عمق محدد."""
        if depth not in self.epistemology_keywords:
            depth = "متوسط"
        keywords = self.epistemology_keywords[depth]

        scores = {cat: 0 for cat in keywords.keys()}
        evidence = []

        for category, words in keywords.items():
            count = 0
            for word in words:
                count += len(re.findall(rf'\b{word}\b', text, re.I))
            scores[category] = count
            if count > 0:
                evidence.append(f"{depth}: كلمات من فئة '{category}' ({count})")

        total = sum(scores.values())
        if total > 0:
            for cat in scores:
                scores[cat] = round(scores[cat] / total, 3)

        dominant = max(scores, key=scores.get) if scores else EpistemologicalCategory.EMPIRICIST
        confidence = min(1.0, len(evidence) / 10)

        return EpistemologicalProfile(
            dominant_category=dominant,
            scores=scores,
            evidence=evidence[:5],
            confidence=confidence,
            root_depth=depth
        )

    def analyze_full_depth(self, text: str) -> Dict[str, Any]:
        """تحليل كامل على جميع المستويات."""
        results = {}
        for depth in self.depth_levels:
            results[depth] = {
                "ontology": self.analyze_ontology(text, depth),
                "epistemology": self.analyze_epistemology(text, depth)
            }
        return results

