# 1. التعريفات الأساسية (الفئات والثوابت)
# ============================================================

class OntologicalCategory:
    """فئات الأنطولوجيا (نماذج الوجود)"""
    MATERIALIST = "مادية"
    IDEALIST = "مثالية"
    DUALIST = "ثنائية"
    PHENOMENAL = "ظاهراتية"
    RELATIONAL = "علائقية"
    PROCESSUAL = "عملية"
    EMERGENT = "ناشئة"
    # فئة إضافية للجذور العميقة
    TRANSCENDENT = "متجاوزة"

class EpistemologicalCategory:
    """فئات الإبستمولوجيا (مصادر المعرفة)"""
    RATIONALIST = "عقلانية"
    EMPIRICIST = "تجريبية"
    INTUITIVE = "حدسية"
    REVELATORY = "وحيانية"
    PRAGMATIC = "براغماتية"
    CONSTRUCTIVIST = "بنائية"
    CRITICAL = "نقدية"
    # فئة إضافية للجذور العميقة
    TRANSCENDENTAL = "متسامية"

@dataclass
class OntologicalProfile:
    dominant_category: str
    scores: Dict[str, float]
    evidence: List[str]
    confidence: float
    root_depth: str = "متوسط"  # سطحي، متوسط، عميق
    lineage: List[str] = field(default_factory=list)

@dataclass
class EpistemologicalProfile:
    dominant_category: str
    scores: Dict[str, float]
    evidence: List[str]
    confidence: float
    root_depth: str = "متوسط"
    lineage: List[str] = field(default_factory=list)

@dataclass
class EpistemologicalRupture:
    id: str
    entity_id: str
    from_ontology: str
    to_ontology: str
    from_epistemology: str
    to_epistemology: str
    rupture_point: str
    description: str
    severity: float
    timestamp: str
    predicted: bool = False
    prediction_confidence: float = 0.0

@dataclass
class PhilosophicalIdentity:
    entity_id: str
    ontological_dominant: str
    epistemological_dominant: str
    root_depth: str
    lineage: List[str]
    transformation_stage: str  # egg, larva, pupa, butterfly
    stability_score: float

