from fastapi import APIRouter, HTTPException

router = APIRouter(prefix="/api/v2/epistemic-ontological", tags=["Epistemic-Ontological Governance"])

_engine = None

def get_engine() -> EpistemicOntologicalEngineV2:
    global _engine
    if _engine is None:
        _engine = EpistemicOntologicalEngineV2()
    return _engine

@router.post("/analyze")
async def analyze_text(text: str, entity_id: str = None):
    """تحليل النص من منظور أنطولوجي وإبستمولوجي (بمستويات متعددة)."""
    engine = get_engine()
    return engine.analyze_text(text, entity_id)

@router.get("/entity/{entity_id}/identity")
async def get_philosophical_identity(entity_id: str):
    """استرجاع الهوية الفلسفية للكيان."""
    engine = get_engine()
    identity = engine.get_philosophical_identity(entity_id)
    if not identity:
        raise HTTPException(status_code=404, detail="Entity not found or not analyzed yet.")
    return identity

@router.get("/entity/{entity_id}/history")
async def get_entity_history(entity_id: str, limit: int = 20):
    """استرجاع التاريخ المعرفي للكيان."""
    engine = get_engine()
    return {"history": engine.get_history(entity_id, limit)}

@router.get("/entity/{entity_id}/predictions")
async def get_predictions(entity_id: str):
    """التنبؤ بالتحولات المعرفية المستقبلية."""
    engine = get_engine()
    if entity_id not in engine.rupture_detector.history:
        raise HTTPException(status_code=404, detail="Entity not found or not analyzed yet.")
    predictions = engine.rupture_detector.predict_rupture(entity_id)
    return {"predictions": predictions}

