# 5. متتبع السلالة المعرفية (Knowledge Lineage Tracker)
# ============================================================

class KnowledgeLineageTracker:
    """
    يتتبع أصل الأفكار (سلالة المعرفة) من خلال تحليل التشابه الدلالي والزمني.
    """

    def __init__(self):
        self.lineage_graph: Dict[str, List[str]] = defaultdict(list)  # idea_id -> parent_ids
        self.idea_store: Dict[str, Dict] = {}

    def register_idea(self, text: str, entity_id: str) -> str:
        """تسجيل فكرة جديدة واستخراج سلالتها."""
        idea_id = hashlib.md5(f"{text[:100]}_{entity_id}_{datetime.utcnow().isoformat()}".encode()).hexdigest()[:16]
        self.idea_store[idea_id] = {
            "text": text[:500],
            "entity_id": entity_id,
            "timestamp": datetime.utcnow().isoformat(),
            "fingerprint": self._extract_fingerprint(text)
        }
        return idea_id

    def _extract_fingerprint(self, text: str) -> str:
        """استخراج بصمة دلالية للنص (مجموعة من الكلمات المفتاحية)."""
        # بسيط: استخراج الكلمات الأكثر تكراراً
        words = re.findall(r'\b\w{4,}\b', text.lower())
        common = [w for w in set(words) if words.count(w) > 1 and w not in ["هذا", "ذلك", "على", "في", "من"]]
        return " ".join(common[:10])

    def find_lineage(self, text: str, entity_id: str) -> List[str]:
        """البحث عن سلالة فكرة جديدة."""
        fingerprint = self._extract_fingerprint(text)
        candidates = []
        for idea_id, idea in self.idea_store.items():
            if idea["entity_id"] != entity_id:
                continue
            similarity = self._calculate_similarity(fingerprint, idea["fingerprint"])
            if similarity > 0.5:
                candidates.append((idea_id, similarity))

        # ترتيب حسب التشابه
        candidates.sort(key=lambda x: x[1], reverse=True)
        return [c[0] for c in candidates[:3]]

    def _calculate_similarity(self, fp1: str, fp2: str) -> float:
        """حساب التشابه بين بصمتين."""
        if not fp1 or not fp2:
            return 0.0
        words1 = set(fp1.split())
        words2 = set(fp2.split())
        intersection = words1 & words2
        union = words1 | words2
        return len(intersection) / len(union) if union else 0.0

